#!/bin/bash

export KMP_DUPLICATE_LIB_OK=TRUE
export QT_QPA_PLATFORM=xcb
export JULIA_PKG_SERVER_REGISTRY_PREFERENCE="eager"

# Add only a minimal set of Conda shared libraries needed at runtime.
# Loading the full Conda lib directory can override Julia/system libs (SuiteSparse,
# Python deps), so we expose only selected compatibility libraries.
_repo_root="$(cd "$(dirname "$0")/.." && pwd)"
_conda_env=""
if [[ -d "${_repo_root}/.CondaPkg/env" ]]; then
    _conda_env="${_repo_root}/.CondaPkg/env"
elif [[ -d "${_repo_root}/.CondaPkg/.pixi/envs/default" ]]; then
    _conda_env="${_repo_root}/.CondaPkg/.pixi/envs/default"
fi

if [[ -n "${_conda_env}" ]]; then
    export CONDA_PREFIX="${_conda_env}"
    export PATH="${_conda_env}/bin:${PATH}"

    # Only Linux uses the shared-library shim (LD_LIBRARY_PATH, .so files).
    if [[ "${OSTYPE}" == linux* ]]; then
        _compat_lib_dir="${_repo_root}/.CondaPkg/compat_libs"
        mkdir -p "${_compat_lib_dir}"

        # Keep this list intentionally short to avoid broad symbol conflicts.
        if [[ -f "${_conda_env}/lib/libiconv.so.2" ]]; then
            ln -sfn "${_conda_env}/lib/libiconv.so.2" "${_compat_lib_dir}/libiconv.so.2"
        fi

        # Prefer Julia artifact OpenSSL libs (they must match OpenSSL_jll ABI),
        # then fall back to Conda if no artifact copy is available.
        _artifact_libcrypto="$(find "${HOME}/.julia/artifacts" -type f -path '*/lib/libcrypto.so.3' 2>/dev/null | head -n 1)"
        _artifact_libssl="$(find "${HOME}/.julia/artifacts" -type f -path '*/lib/libssl.so.3' 2>/dev/null | head -n 1)"

        if [[ -n "${_artifact_libcrypto}" ]]; then
            ln -sfn "${_artifact_libcrypto}" "${_compat_lib_dir}/libcrypto.so.3"
        elif [[ -f "${_conda_env}/lib/libcrypto.so.3" ]]; then
            ln -sfn "${_conda_env}/lib/libcrypto.so.3" "${_compat_lib_dir}/libcrypto.so.3"
        fi

        if [[ -n "${_artifact_libssl}" ]]; then
            ln -sfn "${_artifact_libssl}" "${_compat_lib_dir}/libssl.so.3"
        elif [[ -f "${_conda_env}/lib/libssl.so.3" ]]; then
            ln -sfn "${_conda_env}/lib/libssl.so.3" "${_compat_lib_dir}/libssl.so.3"
        fi

        if [[ -d "${_compat_lib_dir}" ]]; then
            export LD_LIBRARY_PATH="${_compat_lib_dir}:${LD_LIBRARY_PATH:-}"
        fi
    fi
fi

# total memory in kB
MEM=$(grep MemTotal /proc/meminfo | awk '{print $2}')
if (( $MEM >=  15000000 )); then
    export MPLBACKEND=qt5agg
fi

if [[ $(basename $(pwd)) == "bin" ]]; then
    cd ..
fi

if [[ $HOSTNAME == "tuxedi" ]]; then
    sudo performance.sh
fi


# Build the startup expression; optionally include a user-provided script
if [[ -n "${1:-}" ]]; then
    EX="-e include(\"src/init.jl\");include(\"${1}\")"
else
    EX='-e include("src/init.jl")'
fi

julia_version=$(julia --version | awk '{print($3)}')
julia_major=${julia_version:0:3} 
if [[ $julia_major == "1.1" ]]; then
    julia_major=${julia_version:0:4} 
fi

if [[ $julia_major == "1.9" ]]; then
    GCT=""
else
    if [[ $HOSTNAME == "ufryzen" || $HOSTNAME == "TUD262682" ]]; then
        GCT="--gcthreads=8,1"
    else
        GCT="--gcthreads=4,1"
    fi
fi

if test -f "bin/kps-image-${julia_major}.so"; then
    echo "Found system image!"
    if [[ $HOSTNAME == "TUD262682" ]]; then
        julia -J  bin/kps-image-${julia_major}.so --project -i -q -t 10 $GCT $EX
    elif [[ $HOSTNAME == "ufryzen" ]]; then
        julia -J  bin/kps-image-${julia_major}.so --project -i -q -t 16 $GCT $EX
    else
        julia -J  bin/kps-image-${julia_major}.so --project -i -q -t 8 $GCT $EX
    fi
else
    if [[ $HOSTNAME == "ufryzen" ]]; then
        julia --project -i -q -t 16 $GCT $EX
    else
        julia --project -i -q -t 8 $GCT $EX
    fi
fi
